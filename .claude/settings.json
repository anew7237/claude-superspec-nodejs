{
  "_comment": "團隊共用的 Claude Code 設定。會進 git。個人偏好放 ~/.claude/settings.json (host 端,不進此 repo)",

  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(pnpm:*)",
      "Bash(pnpx:*)",
      "Bash(node:*)",
      "Bash(tsc:*)",
      "Bash(vitest:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(uv:*)",
      "Bash(specify:*)",
      "Bash(make:*)",
      "Bash(curl:*)",
      "Bash(jq:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(sudo rm:*)"
    ]
  },

  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000"
  }
}
